# ── Mail — option A: Resend (recommended for Vercel) ──────────────────────────
# Get your free API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Mail — option B: Gmail SMTP fallback ──────────────────────────────────────
# Use an App Password (not your real password): https://myaccount.google.com/apppasswords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Lead destination email ────────────────────────────────────────────────────
# Where lead emails should be delivered (defaults to GMAIL_USER if not set)
LEAD_TO_EMAIL=ankara@brainfit.com.tr

# ── Admin paneli (Prompt 07'de kullanılacak) ──────────────────────────────────
ADMIN_PASSWORD=guclu-sifre-gir

# ── Site URL (deploy sonrası güncelle) ────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://brainfitankara.com

# ── Google Search Console doğrulama kodu ─────────────────────────────────────
# Google Search Console > Mülk Ekle > HTML meta etiketi yöntemindeki "content" değeri
NEXT_PUBLIC_GSC_VERIFICATION=
