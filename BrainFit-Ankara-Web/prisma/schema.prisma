generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  bio       String
  tags      String   @default("")
  color     String   @default("#00B4E5")
  imageUrl  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id        String   @id @default("main")
  phone     String   @default("")
  whatsapp  String   @default("")
  email     String   @default("")
  address   String   @default("")
  hours     String   @default("")
  mapsEmbed String   @default("")
  updatedAt DateTime @updatedAt
}

model SmtpSettings {
  id        String   @id @default("main")
  host      String   @default("smtp.gmail.com")
  port      Int      @default(587)
  user      String   @default("")
  password  String   @default("")
  fromName  String   @default("BrainFit Ankara")
  toEmail   String   @default("")
  updatedAt DateTime @updatedAt
}

model BlogCategory {
  id    String     @id @default(cuid())
  name  String
  color String     @default("#00B4E5")
  posts BlogPost[]
}

model PageImage {
  key       String   @id
  url       String
  altText   String   @default("")
  updatedAt DateTime @updatedAt
}

model TestLead {
  id             String    @id @default(cuid())
  veliAdSoyad    String
  telefon        String
  email          String
  testKiminIcin  String    @default("Çocuğum")
  cocukAd        String    @default("")
  cocukYas       Int?
  sehir          String    @default("")
  kvkkOnay       Boolean   @default(false)
  veliOnay18Alti Boolean   @default(false)
  kaynak         String    @default("mini-test")
  ageGroup       String    @default("")
  scores         Json?
  rawMetrics     Json?
  completed      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
}

model MediaFile {
  id        String   @id @default(cuid())
  url       String
  filename  String
  size      Int      @default(0)
  mimeType  String   @default("")
  createdAt DateTime @default(now())
}

model Appointment {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String   @default("")
  childAge      String   @default("")
  preferredDate String
  preferredTime String
  note          String   @default("")
  scores        Json?
  source        String   @default("result-page")
  status        String   @default("pending")
  createdAt     DateTime @default(now())
}

model BlogPost {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  content     String
  excerpt     String       @default("")
  imageUrl    String?
  categoryId  String
  category    BlogCategory @relation(fields: [categoryId], references: [id])
  tags        String       @default("")
  published   Boolean      @default(false)
  publishedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}
